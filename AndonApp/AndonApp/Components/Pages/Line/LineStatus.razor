@page "/line/{Slug}"
@using AndonApp.Data
@using AndonApp.Data.Models
@using AndonApp.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<AndonDbContext> DbFactory
@inject IIncidentService IncidentService
@inject NavigationManager Nav
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>@(_line?.Name ?? "ANDON") – Status</PageTitle>

@if (!_authorized)
{
    <div class="line-unauthorized">
        <h1>Access Denied</h1>
        <p>Invalid production line or access token.</p>
    </div>
}
else
{
    <div class="line-top-bar top-bar-@GetBoardClass()">
        <span class="top-bar-line-name">@_line!.Name</span>
        <span class="work-status-badge work-status-@GetWorkStatusClass()">@GetWorkStatus()</span>
        <div class="top-bar-clock">
            <div class="clock-time">@_now.ToString("HH:mm:ss")</div>
            <div class="clock-date">@_now.ToString("dddd dd MMMM yyyy")</div>
        </div>
    </div>

    <div class="status-board @GetBoardClass()" @onclick="HideModal">

        <div class="stat-row" @onclick:stopPropagation>
            <div class="stat-card @GetStatCardClass()">
                <div class="stat-card-label">Scheduled</div>
                <div class="stat-card-value">@(GetTotalWorkingMinutes() is int m ? FormatMinutes(m) : "–")</div>
                @if (_todaySchedule != null && _todaySchedule.IsWorkday)
                {
                    <div class="stat-card-sub">@Fmt(_todaySchedule.StartTime) – @Fmt(_todaySchedule.EndTime)</div>
                }
            </div>
            <div class="stat-card @GetStatCardClass()">
                <div class="stat-card-label">Elapsed</div>
                <div class="stat-card-value">@(GetElapsedMinutes() is int e ? FormatMinutes(e) : "–")</div>
            </div>
            <div class="stat-card @GetStatCardClass()">
                <div class="stat-card-label">Target</div>
                <div class="stat-card-value">@(_todayTarget.HasValue ? _todayTarget.Value.ToString("N0") : "–")</div>
            </div>
            <div class="stat-card stat-card-empty"></div>
            <div class="stat-card stat-card-empty"></div>
        </div>

        <div class="board-content">
            @if (!_incidents.Any())
            {
                <div class="all-ok">
                    <div class="all-ok-text">ALL OK</div>
                    <div class="all-ok-line">@_line!.Name</div>
                </div>
            }
            else
            {
                <div class="incident-board">
                    <div class="board-header">
                        <div class="board-line-name">@_line!.Name</div>
                        <div class="board-status-badge">@GetWorstSeverity() ALERT</div>
                    </div>
                    <div class="incident-list">
                        @foreach (var incident in _incidents)
                        {
                            <div class="incident-card @GetIncidentClass(incident)" @onclick:stopPropagation>
                                <div class="incident-severity">@incident.Severity</div>
                                <div class="incident-code">
                                    <strong>@incident.AndonCode</strong>
                                    @if (!string.IsNullOrEmpty(incident.AndonCodeName))
                                    {
                                        <span class="incident-code-name"> – @incident.AndonCodeName</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(incident.AdditionalInfo))
                                {
                                    <div class="incident-info">@incident.AdditionalInfo</div>
                                }
                                <div class="incident-time">
                                    Opened: @incident.CreatedAt.ToLocalTime().ToString("HH:mm:ss dd-MMM-yyyy")
                                </div>
                                @if (_closeError != null && _closeErrorId == incident.Id)
                                {
                                    <div class="alert alert-error">@_closeError</div>
                                }
                                <button class="btn-close-incident"
                                        @onclick="() => CloseIncident(incident.Id)"
                                        @onclick:stopPropagation
                                        disabled="@(_closingId == incident.Id)">
                                    @(_closingId == incident.Id ? "Closing..." : "✓ Close Incident")
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <button class="btn-new-incident" @onclick="ShowNewIncidentModal" @onclick:stopPropagation>
            + New Incident
        </button>
    </div>
}

@if (_showModal)
{
    <div class="modal-backdrop" @onclick="HideModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>New Incident</h2>
                <button class="modal-close" @onclick="HideModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert alert-error">@_modalError</div>
                }
                <div class="form-group">
                    <label>ANDON Code *</label>
                    <select class="form-control" @bind="_form.AndonCodeId">
                        <option value="0">-- Select ANDON Code --</option>
                        @foreach (var code in _activeCodes)
                        {
                            <option value="@(code.Id)">
                                @(code.Code) @(code.Name != null ? $"– {code.Name}" : "")
                            </option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Severity *</label>
                    <div class="severity-select">
                        <button type="button"
                                class="severity-btn @(_form.Severity == Severity.AMBER ? "selected-amber" : "")"
                                @onclick="() => _form.Severity = Severity.AMBER">
                            AMBER
                        </button>
                        <button type="button"
                                class="severity-btn @(_form.Severity == Severity.RED ? "selected-red" : "")"
                                @onclick="() => _form.Severity = Severity.RED">
                            RED
                        </button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Additional Info</label>
                    <textarea class="form-control"
                              @bind="_form.AdditionalInfo"
                              rows="4"
                              placeholder="Describe the issue..."
                              maxlength="1000"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="HideModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SubmitIncident" disabled="@_submitting">
                    @(_submitting ? "Raising..." : "Raise Incident")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private ProductionLine? _line;
    private bool _authorized;
    private List<IncidentSummaryDto> _incidents = new();
    private List<AndonCode> _activeCodes = new();

    private bool _showModal;
    private IncidentForm _form = new();
    private string? _modalError;
    private bool _submitting;

    private int? _closingId;
    private string? _closeError;
    private int? _closeErrorId;

    private HubConnection? _hubConnection;

    // Clock + schedule + target
    private DateTime _now = DateTime.Now;
    private DayOfWeek _loadedDay;
    private LineSchedule? _todaySchedule;
    private int? _todayTarget;
    private Timer? _clockTimer;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _line = await db.ProductionLines
            .FirstOrDefaultAsync(l => l.Slug == Slug && l.IsActive);

        if (_line == null || string.IsNullOrEmpty(Token) || _line.AccessToken != Token)
        {
            _authorized = false;
            return;
        }

        _authorized = true;
        await LoadIncidentsAsync();
        await LoadScheduleAsync();
        await LoadTodayTargetAsync();

        await using var db2 = await DbFactory.CreateDbContextAsync();
        _activeCodes = await db2.AndonCodes
            .Where(c => c.IsActive)
            .OrderBy(c => c.Code)
            .ToListAsync();

        await ConnectSignalRAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _authorized)
            _clockTimer = new Timer(OnClockTick, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
        return Task.CompletedTask;
    }

    private void OnClockTick(object? _)
    {
        _ = InvokeAsync(async () =>
        {
            _now = DateTime.Now;
            if (_now.DayOfWeek != _loadedDay)
                await LoadScheduleAsync();
            StateHasChanged();
        });
    }

    private async Task LoadScheduleAsync()
    {
        if (_line == null) return;
        _loadedDay = DateTime.Now.DayOfWeek;
        await using var db = await DbFactory.CreateDbContextAsync();
        _todaySchedule = await db.LineSchedules
            .Include(s => s.Breaks)
            .FirstOrDefaultAsync(s => s.ProductionLineId == _line.Id && s.DayOfWeek == _loadedDay);
        await LoadTodayTargetAsync();
    }

    private async Task LoadTodayTargetAsync()
    {
        if (_line == null) return;
        var today = DateOnly.FromDateTime(DateTime.Today);
        await using var db = await DbFactory.CreateDbContextAsync();
        var t = await db.LineTargets
            .FirstOrDefaultAsync(t => t.ProductionLineId == _line.Id && t.Date == today);
        _todayTarget = t?.Target;
    }

    private string GetWorkStatus()
    {
        if (_todaySchedule == null || !_todaySchedule.IsWorkday)
            return "Overtime";

        var t = _now.TimeOfDay;

        if (t < _todaySchedule.StartTime || t >= _todaySchedule.EndTime)
            return "Overtime";

        foreach (var brk in _todaySchedule.Breaks)
            if (t >= brk.StartTime && t < brk.EndTime)
                return brk.Name;

        return "Working";
    }

    private string GetWorkStatusClass() => GetWorkStatus() switch
    {
        "Working" => "working",
        "Overtime" => "overtime",
        _ => "break"
    };

    private int? GetTotalWorkingMinutes()
    {
        if (_todaySchedule == null || !_todaySchedule.IsWorkday) return null;
        var total = (_todaySchedule.EndTime - _todaySchedule.StartTime).TotalMinutes;
        var breakMins = _todaySchedule.Breaks.Sum(b => (b.EndTime - b.StartTime).TotalMinutes);
        return (int)(total - breakMins);
    }

    private int? GetElapsedMinutes()
    {
        if (_todaySchedule == null || !_todaySchedule.IsWorkday) return null;
        var t = _now.TimeOfDay;
        if (t < _todaySchedule.StartTime) return 0;

        var elapsed = (t - _todaySchedule.StartTime).TotalMinutes;

        foreach (var brk in _todaySchedule.Breaks)
        {
            if (t >= brk.EndTime)
                elapsed -= (brk.EndTime - brk.StartTime).TotalMinutes;
            else if (t > brk.StartTime)
                elapsed -= (t - brk.StartTime).TotalMinutes;
        }

        var totalWorking = (_todaySchedule.EndTime - _todaySchedule.StartTime).TotalMinutes
                           - _todaySchedule.Breaks.Sum(b => (b.EndTime - b.StartTime).TotalMinutes);

        return (int)Math.Min(Math.Max(elapsed, 0), totalWorking);
    }

    private static string Fmt(TimeSpan t) => t.ToString(@"hh\:mm");

    private static string FormatMinutes(int minutes)
    {
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m:D2}m" : $"{m}m";
    }

    private async Task ConnectSignalRAsync()
    {
        var hubUrl = Nav.ToAbsoluteUri("/hubs/andon");
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<IncidentSummaryDto>("IncidentCreated", async (dto) =>
        {
            await InvokeAsync(() =>
            {
                _incidents.Add(dto);
                _incidents = _incidents.OrderBy(i => i.CreatedAt).ToList();
                StateHasChanged();
            });
        });

        _hubConnection.On<int>("IncidentClosed", async (id) =>
        {
            await InvokeAsync(() =>
            {
                _incidents.RemoveAll(i => i.Id == id);
                StateHasChanged();
            });
        });

        await _hubConnection.StartAsync();
        await _hubConnection.InvokeAsync("JoinLine", Slug, Token);
    }

    private async Task LoadIncidentsAsync()
    {
        if (_line == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        _incidents = await db.Incidents
            .Where(i => i.ProductionLineId == _line.Id && i.Status == IncidentStatus.OPEN)
            .OrderBy(i => i.CreatedAt)
            .Select(i => new IncidentSummaryDto(
                i.Id,
                i.Severity,
                i.AndonCode.Code,
                i.AndonCode.Name,
                i.AdditionalInfo,
                i.CreatedAt))
            .ToListAsync();
    }

    private string GetBoardClass() => _incidents.Any()
        ? (_incidents.Any(i => i.Severity == Severity.RED) ? "status-red" : "status-amber")
        : "status-green";

    private string GetStatCardClass() => _incidents.Any()
        ? (_incidents.Any(i => i.Severity == Severity.RED) ? "stat-card-red" : "stat-card-amber")
        : "stat-card-green";

    private string GetWorstSeverity() => _incidents.Any()
        ? (_incidents.Any(i => i.Severity == Severity.RED) ? "RED" : "AMBER")
        : "GREEN";

    private string GetIncidentClass(IncidentSummaryDto i) =>
        i.Severity == Severity.RED ? "incident-red" : "incident-amber";

    private void ShowNewIncidentModal()
    {
        _form = new IncidentForm();
        _modalError = null;
        _showModal = true;
    }

    private void HideModal()
    {
        _showModal = false;
        _modalError = null;
    }

    private async Task SubmitIncident()
    {
        if (_form.AndonCodeId == 0)
        {
            _modalError = "Please select an ANDON code.";
            return;
        }

        _submitting = true;
        _modalError = null;

        try
        {
            await IncidentService.CreateIncidentAsync(
                _line!.Id,
                _form.AndonCodeId,
                _form.Severity,
                string.IsNullOrWhiteSpace(_form.AdditionalInfo) ? null : _form.AdditionalInfo.Trim());

            HideModal();
        }
        catch (Exception ex)
        {
            _modalError = $"Failed to raise incident: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task CloseIncident(int incidentId)
    {
        _closingId = incidentId;
        _closeError = null;
        _closeErrorId = null;

        try
        {
            await IncidentService.CloseIncidentAsync(incidentId, _line!.Id);
        }
        catch (Exception ex)
        {
            _closeError = $"Failed to close incident: {ex.Message}";
            _closeErrorId = incidentId;
        }
        finally
        {
            _closingId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _clockTimer?.Dispose();
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    private class IncidentForm
    {
        public int AndonCodeId { get; set; }
        public Severity Severity { get; set; } = Severity.AMBER;
        public string? AdditionalInfo { get; set; }
    }
}
