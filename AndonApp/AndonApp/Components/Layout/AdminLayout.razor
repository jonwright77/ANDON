@inherits LayoutComponentBase

<div class="admin-shell">
    <nav class="admin-nav">
        <div class="admin-nav-brand">ANDON Admin</div>
        <div class="admin-nav-links">
            <a href="/admin/overview">Overview</a>
            <a href="/admin/andon-codes">ANDON Codes</a>
            <a href="/admin/lines">Production Lines</a>
            <a href="/admin/line-types">Line Types</a>
            <a href="/admin/todays-targets">Today's Targets</a>
            <a href="/admin/email-settings">Email Settings</a>
            <a href="/admin/erp-settings">ERP Settings</a>
            <button class="theme-toggle" onclick="andonTheme.toggle()" title="Toggle dark mode"></button>
            <form method="post" action="/admin/logout" @formname="logout-form" style="display:inline">
                <AntiforgeryToken />
                <button type="submit" class="btn-link">Logout</button>
            </form>
        </div>
    </nav>
    <main class="admin-main">
        @Body
    </main>
</div>
